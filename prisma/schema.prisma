generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

model MedicalHistory {
  id          String @id @map("_id") @db.ObjectId
  age         String
  weight      String
  height      String
  allergies   String
  medications String
  medicalConditions String
}
